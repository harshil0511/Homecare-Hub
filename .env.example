# Copy this file to .env and fill in your values
# .env is gitignored and will never be committed

# PostgreSQL
POSTGRES_USER=homecare_user
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=homecare

# Backend
DATABASE_URL=postgresql+psycopg://homecare_user:your_db_password_here@postgres:5432/homecare
SECRET_KEY=generate-a-random-64-char-hex-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Superadmin (auto-seeded on first startup)
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=YourStrongPassword@123
SUPERADMIN_USERNAME=Super Admin

# CORS
FRONTEND_URL=http://localhost:3000

# Optional: Anthropic AI integration
ANTHROPIC_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8002
